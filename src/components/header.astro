---
const { profile, avatarClass } = Astro.props;
---

<div class="text-center mb-10 animate-fade-in">

	<img
		src={profile.avatar || "avatar/Avatar.webp"}
		alt={`${profile.name} avatar`}
		width="110"
		height="110"
		class={`${avatarClass} shadow-xl`}
	/>

	<h1
		class="mt-6 text-5xl font-black tracking-wide leading-tight"
		style="
			background:linear-gradient(180deg,#3E8E41 0%,#1B5E20 100%);
			-webkit-background-clip:text;
			-webkit-text-fill-color:transparent;
			text-shadow:
			0 2px 0 rgba(255,255,255,.9),
			0 5px 12px rgba(0,0,0,.15);
		"
	>
		{profile.name}
	</h1>

	<p class="mt-3 text-xl font-medium text-gray-800">
		{profile.description}
	</p>

	<p class="mt-5 text-2xl font-extrabold text-red-700">
		☎️ 0854 815 813
	</p>

</div>
