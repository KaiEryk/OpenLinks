---
const { profile, avatarClass } = Astro.props;
---

<div class="text-center mb-6 animate-fade-in">

	<img
		src={profile.avatar || "avatar/Avatar.webp"}
		alt={`${profile.name} avatar`}
		class="w-32 sm:w-36 md:w-40 h-auto mx-auto object-contain"
	/>

<h1 class="mt-4 text-center leading-none">

	<span
		class="block text-lg sm:text-xl font-semibold uppercase tracking-[0.25em] text-[#2E7D32]"
	>
		BÁCH HOÁ
	</span>

	<span
		class="block mt-2 text-4xl sm:text-5xl lg:text-6xl font-black tracking-wide"
		style="
			background:linear-gradient(180deg,#2E7D32,#1B5E20);
			-webkit-background-clip:text;
			-webkit-text-fill-color:transparent;
		"
	>
		GIANG SEN
	</span>

</h1>

	<div class="flex items-center justify-center my-3">
		<div class="h-px w-16 sm:w-20 bg-green-300"></div>

		<span class="mx-3 text-green-600 text-2xl">
			🌾 &nbsp; 🌾
		</span>

		<div class="h-px w-16 sm:w-20 bg-green-300"></div>
	</div>

	<p class="text-base sm:text-lg font-medium text-gray-800">
		{profile.description}
	</p>

	<p class="mt-4 text-xl sm:text-2xl font-extrabold text-red-700">
		☎️ 0854 815 813
	</p>

</div>
