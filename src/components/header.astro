---
const { profile, avatarClass } = Astro.props;
---

<div class="text-center mb-10 animate-fade-in">

	<img
		src={profile.avatar || "avatar/Avatar.webp"}
		alt={`${profile.name} avatar`}
		width="110"
		height="110"
		class={`${avatarClass} shadow-xl`}
	/>

	<h1 class="mt-6 leading-none text-center">
		<span class="block text-4xl font-bold text-green-800 tracking-wide">
			Bách Hoá
		</span>

		<span
			class="block text-6xl font-black tracking-wide mt-1"
			style="background:linear-gradient(180deg,#2E7D32,#1B5E20);-webkit-background-clip:text;-webkit-text-fill-color:transparent;filter:drop-shadow(0 3px 6px rgba(0,0,0,.2));"
		>
			GIANG SEN
		</span>
	</h1>

	<div class="flex items-center justify-center my-4">
		<div class="h-px w-20 bg-green-300"></div>

		<span class="mx-3 text-green-600 text-2xl">
			🪷
		</span>

		<div class="h-px w-20 bg-green-300"></div>
	</div>

	<p class="text-xl font-medium text-gray-800">
		{profile.description}
	</p>

	<p class="mt-5 text-2xl font-extrabold text-red-700">
		☎️ 0854 815 813
	</p>

</div>
